{
    "manifest_version": 3,
    "name": "__MSG_extensionName__",
    "version": "1.7",
    "description": "__MSG_extensionDescription__",
    "default_locale": "fr",
    "browser_specific_settings": {
        "gecko": {
            "id": "stream_catcher_fdm@freedownloadmanager.org",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        }
    },
    "permissions": [
        "webRequest",
        "webNavigation",
        "storage",
        "tabs",
        "downloads",
        "nativeMessaging",
        "cookies"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "scripts": [
            "background.js"
        ]
    },
    "options_ui": {
        "page": "options.html"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "all_frames": true,
            "run_at": "document_end"
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "FDM Stream Capture"
    },
    "icons": {
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}